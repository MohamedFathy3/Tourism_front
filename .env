# Server Configuration
VITE_DEV_SERVER_HOST=::
VITE_DEV_SERVER_PORT=7000
VITE_PREVIEW_SERVER_HOST=::
VITE_PREVIEW_SERVER_PORT=7002

# API Configuration
VITE_API_TARGET=https://selimfaraggroup.com/
VITE_API_REWRITE_PATH=/api
VITE_API_HEADER_NAME=X-Requested-With
